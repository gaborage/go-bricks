# Allowlisting gitignore template for GO projects prevents us
# from adding various unwanted local files, such as generated
# files, developer configurations or IDE-specific files etc.
#
# Recommended: Go.AllowList.gitignore

# Ignore everything
*

.gomodcache/

# But not these files...
!/.gitignore

!*.go
!go.sum
!go.mod

!README.md
!LICENSE
!TESTING.md
!TODO.md
!CONTRIBUTING.md
!MULTI_TENANT.md
!CLAUDE.md
!llms.txt
!context7.json

!Makefile

# Example files
!.env.example
!config.example.yaml

!wiki/*

!docs/superpowers/specs/*.md
!docs/superpowers/plans/*.md

!.github/workflows/*.yml
!.github/workflows/*.yaml
!.github/ISSUE_TEMPLATE/*.yml

!sonar-project.properties

!.claude/commands/*
!.claude/settings.json
!.claude/hooks/*
!.claude/agents/*
!.claude/skills/**

# Test fixtures (JSON / SQL / golden files) live under testdata/ alongside the
# source they exercise.
!**/testdata/**/*.json
!**/testdata/**/*.sql
# Golden OpenAPI specs for the openapi tool's round-trip harness.
!**/testdata/**/*.yaml

# OpenAPI tool redocly lint config (referenced by `make validate-spec` in CI).
!tools/openapi/redocly.yaml

# ...even if they are in subdirectories
!*/

# Explicit ignores (override !*/ above)
.claude/worktrees/